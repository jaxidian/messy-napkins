{
  "name": "quick-local-baseline",
  "model": {
    "id": "example-model-q4",
    "engine": {
      "name": "ollama",
      "version": "0.1.34",
      "accelerator": "vulkan",
      "startup_flags": []
    },
    "hardware": {
      "gpu": "AMD RX 7900 XTX",
      "vram_gb": 24.0,
      "cpu": "AMD Ryzen 9 7950X",
      "os": "Ubuntu 24.04",
      "device_count": 1,
      "driver_version": "",
      "runtime_version": ""
    },
    "quantization": "Q4_K_M",
    "parameter_count": "7B",
    "seed": 42,
    "max_tokens": 1024,
    "context_size": 32768,
    "parameters": {
      "temperature": 0.2,
      "top_p": 0.95
    },
    "source": "",
    "revision": "",
    "artifact_filename": "",
    "artifact_checksum": ""
  },
  "runner": {
    "type": "http",
    "url": "http://localhost:11434/v1/chat/completions",
    "timeout_seconds": 30
  },
  "aislop": {
    "command": [
      "python3",
      "-c",
      "import json,sys; payload=json.loads(sys.stdin.read()); text=payload['generated_output']; print(json.dumps({'score': len(text) / 10}))"
    ],
    "timeout_seconds": 30
  },
  "output": {
    "path": "logs/benchmark-results.jsonl"
  },
  "cases": [
    {
      "id": "code-gen-slugify",
      "task": "code_gen",
      "prompt": "Implement slugify(text) in Python. Return lowercase hyphen-separated words, remove punctuation, collapse whitespace, and return an empty string for empty input. Include only the implementation in a Python code block.",
      "evaluation": {
        "kind": "python_tests",
        "tests": [
          "assert slugify('Hello, World!') == 'hello-world'",
          "assert slugify('  Multiple   spaces  ') == 'multiple-spaces'",
          "assert slugify('') == ''",
          "assert slugify('A/B test') == 'ab-test'"
        ]
      },
      "trials": 5,
      "warmup_trials": 1
    },
    {
      "id": "code-gen-merge-intervals",
      "task": "code_gen",
      "prompt": "Implement merge_intervals(intervals) in Python. Merge overlapping or touching [start, end] intervals, do not mutate the input, and return intervals sorted by start. Include only the implementation in a Python code block.",
      "evaluation": {
        "kind": "python_tests",
        "tests": [
          "assert merge_intervals([[1, 3], [2, 4], [8, 9]]) == [[1, 4], [8, 9]]",
          "assert merge_intervals([[5, 6], [1, 2], [2, 5]]) == [[1, 6]]",
          "original = [[1, 3], [2, 4]]; merge_intervals(original); assert original == [[1, 3], [2, 4]]",
          "assert merge_intervals([]) == []"
        ]
      },
      "trials": 5,
      "warmup_trials": 1
    },
    {
      "id": "docs-create-user-api",
      "task": "docs",
      "prompt": "Write concise API documentation for POST /v1/users. State authentication, request fields and validation, a successful response, error status codes, and one curl example. Use headings and do not invent guarantees.",
      "evaluation": {
        "kind": "rubric",
        "required_phrases": ["authentication", "request", "response", "status", "curl"],
        "forbidden_phrases": ["guaranteed uptime", "never fails"],
        "minimum_score": 1.0
      },
      "trials": 5,
      "warmup_trials": 1
    },
    {
      "id": "structured-user-result",
      "task": "structured_output",
      "prompt": "Return only JSON with a string 'user_id', a string 'email', and a boolean 'active'. Do not use markdown.",
      "evaluation": {
        "kind": "json_schema",
        "schema": {
          "type": "object",
          "required": ["user_id", "email", "active"],
          "properties": {
            "user_id": {"type": "string"},
            "email": {"type": "string"},
            "active": {"type": "boolean"}
          }
        }
      },
      "trials": 5,
      "warmup_trials": 1
    },
    {
      "id": "instruction-following-exact",
      "task": "instruction_following",
      "prompt": "Reply with exactly the word DONE and nothing else.",
      "expected_answer": "DONE",
      "pass_condition": "exact_match",
      "trials": 5,
      "warmup_trials": 1
    },
    {
      "id": "reasoning-arithmetic",
      "task": "reasoning",
      "prompt": "A shelf has 3 boxes. Each box contains 4 packs, and each pack contains 5 screws. Return only the total number of screws as a base-10 integer.",
      "expected_answer": "60",
      "pass_condition": "exact_match",
      "trials": 5,
      "warmup_trials": 1
    }
  ]
}
