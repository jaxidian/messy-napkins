{
  "name": "quick-local-baseline",
  "model": {
    "id": "example-model-q4",
    "engine": {
      "name": "ollama",
      "version": "0.1.34",
      "accelerator": "vulkan"
    },
    "hardware": {
      "gpu": "AMD RX 7900 XTX",
      "vram_gb": 24.0,
      "cpu": "AMD Ryzen 9 7950X",
      "os": "Ubuntu 24.04"
    },
    "quantization": "Q4_K_M",
    "parameter_count": "7B",
    "seed": 42,
    "max_tokens": 512,
    "context_size": 32768,
    "parameters": {
      "temperature": 0.2,
      "top_p": 0.95
    }
  },
  "runner": {
    "type": "subprocess",
    "command": [
      "python3",
      "-c",
      "import sys; print('stub output for: ' + sys.argv[1])"
    ],
    "timeout_seconds": 30
  },
  "aislop": {
    "command": [
      "python3",
      "-c",
      "import json,sys; text=sys.stdin.read(); print(json.dumps({'score': len(text) / 10}))"
    ],
    "timeout_seconds": 30
  },
  "output": {
    "path": "logs/benchmark-results.jsonl"
  },
  "cases": [
    {
      "id": "code-gen-hello-world",
      "task": "code_gen",
      "prompt": "Write a Python hello world function.",
      "trials": 3
    },
    {
      "id": "docs-api-summary",
      "task": "docs",
      "prompt": "Document an API endpoint that creates a user.",
      "trials": 3
    },
    {
      "id": "prompt-following",
      "task": "system_prompt_following",
      "prompt": "Respond with exactly three bullet points about observability.",
      "trials": 3
    }
  ]
}
